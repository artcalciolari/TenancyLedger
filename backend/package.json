{
  "name": "tenancy-ledger",
  "version": "0.0.1",
  "description": "Backend auditável para gestão de imóveis, contratos e recebimentos de locação.",
  "author": "Arthur David Müzel Calciolari",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=24.11 <25",
    "npm": ">=11"
  },
  "packageManager": "npm@11.6.2",
  "scripts": {
    "build": "nest build",
    "typecheck": "tsc --noEmit --incremental false",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "lint:check": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:ci": "jest --runInBand --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --runTestsByPath ./test/app.e2e-spec.ts --runInBand",
    "test:e2e:ci": "jest --config ./test/jest-e2e.json --runTestsByPath ./test/app.e2e-spec.ts --runInBand --coverage",
    "openapi:generate": "node scripts/openapi-snapshot.mjs",
    "openapi:check": "node scripts/openapi-snapshot.mjs --check",
    "typeorm": "typeorm-ts-node-commonjs -d src/database/data-source.ts",
    "typeorm:prod": "typeorm -d dist/database/data-source.js",
    "migration:create": "npm run typeorm -- migration:create",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:show": "npm run typeorm -- migration:show",
    "migration:run:prod": "npm run typeorm:prod -- migration:run",
    "migration:revert:prod": "npm run typeorm:prod -- migration:revert",
    "migration:show:prod": "npm run typeorm:prod -- migration:show",
    "security:audit": "npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "@smithy/node-http-handler": "^4.9.5",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "helmet": "^8.3.0",
    "joi": "^18.2.3",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.30"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^24.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.9.5",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/*.spec.ts",
      "!**/*.module.ts",
      "!**/*.controller.ts",
      "!**/*.dto.ts",
      "!**/*.typeorm.repository.ts",
      "!database/**",
      "!main.ts",
      "!app.setup.ts",
      "!infrastructure/storage.module.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 75,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
