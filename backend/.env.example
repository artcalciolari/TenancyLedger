# Runtime
NODE_ENV=development
PORT=3000
FRONTEND_PORT=5173
CORS_ORIGINS=http://localhost:5173
SWAGGER_ENABLED=true
LOG_LEVEL=debug

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=tenancyledger
DB_SSL=false
# Production with a private CA: mount PEM files and set DB_SSL_CA_FILE.
# For mTLS, set DB_SSL_CERT_FILE and DB_SSL_KEY_FILE together.
DB_LOGGING=false

# Authentication
# Development-only values. Use a secret manager and strong unique values outside local development.
JWT_SECRET=development-only-jwt-secret-change-me
JWT_EXPIRES_IN=15m
JWT_ISSUER=tenancy-ledger
JWT_AUDIENCE=tenancy-ledger-api
REFRESH_TOKEN_TTL_DAYS=30
AUTH_BOOTSTRAP_EMAIL=admin@example.com
AUTH_BOOTSTRAP_PASSWORD=ChangeMeNow123!

# Abuse protection
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
METRICS_TOKEN=development-metrics-token

# MinIO / S3-compatible object storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=payment-proofs
MINIO_USE_SSL=false
MINIO_AUTO_CREATE_BUCKET=true
STORAGE_SSE_ENABLED=false

# Billing scheduler
INVOICE_CRON_ENABLED=true
INVOICE_CRON_TIME_ZONE=America/Sao_Paulo
INVOICE_GENERATION_DAYS_AHEAD=7
